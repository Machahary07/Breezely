{
  "manifest_version": 3,
  "name": "Breezely Agent",
  "version": "1.0.0",
  "description": "Breezely Automation & Translation Assistant",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "sidePanel"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ]
    }
  ],
  "action": {
    "default_title": "Open Breezely Assistant",
    "default_icon": {
      "16": "breezely-logo-breezely-green.png",
      "32": "breezely-logo-breezely-green.png",
      "48": "breezely-logo-breezely-green.png",
      "128": "breezely-logo-breezely-green.png"
    }
  },
  "icons": {
    "16": "breezely-logo-breezely-green.png",
    "32": "breezely-logo-breezely-green.png",
    "48": "breezely-logo-breezely-green.png",
    "128": "breezely-logo-breezely-green.png"
  },
  "side_panel": {
    "default_path": "sidebar.html"
  }
}